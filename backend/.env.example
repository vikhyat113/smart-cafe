# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Example: mongodb+srv://<user>:<password>@cluster0.mongodb.net/smart-cafe?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/smart-cafe?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Used to build QR code URLs and for CORS
FRONTEND_URL=http://localhost:5173
